# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build artifacts ─────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
build/
.expo/
.expo-shared/
*.tsbuildinfo

# ── Environment & secrets ───────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ── IDEs & editors ──────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Replit-specific ─────────────────────────────────────────────────────────
.cache/
.local/
.replit
replit.nix
.upm/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS & system ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Test coverage ────────────────────────────────────────────────────────────
/coverage

# ── Misc ────────────────────────────────────────────────────────────────────
