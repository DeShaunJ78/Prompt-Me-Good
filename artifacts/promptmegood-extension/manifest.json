{
  "manifest_version": 3,
  "name": "Send to PromptMeGood",
  "short_name": "PromptMeGood",
  "version": "0.1.0",
  "description": "Right-click any text or image on the web and send it straight into PromptMeGood as a starting point for your next prompt.",
  "icons": {
    "16":  "icons/icon-16.png",
    "32":  "icons/icon-32.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Send to PromptMeGood",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "send-to-promptmegood@promptmegood.com",
      "strict_min_version": "121.0"
    }
  }
}
